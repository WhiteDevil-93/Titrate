{"8_cardiovascular": {"antihypertensives": [{"drug": "Amlodipine", "adult_dose": "5-10mg PO daily", "paediatric_dose": "0.1-0.2mg/kg PO daily (age >6yr)"}, {"drug": "Hydralazine", "adult_dose": "5-20mg IV 4-6hrly", "paediatric_dose": "0.1-0.2mg/kg IV 4-6hrly (max 20mg)", "notes_updates": "Avoid in aortic dissection"}, {"drug": "Labetalol", "adult_dose": "10-20mg IV over 2min (may double every 10min)", "paediatric_dose": "0.2-1mg/kg IV", "notes_updates": "Mixed alpha/beta blocker. Good for hypertensive emergencies"}, {"drug": "Esmolol", "adult_dose": "Loading: 500mcg/kg IV; Infusion: 50-200mcg/kg/min IV", "paediatric_dose": "Loading: 500mcg/kg IV; Infusion: 50-200mcg/kg/min IV", "notes_updates": "Ultra-short acting"}], "heart_failure": [{"drug": "Digoxin", "adult_dose": "Loading: 0.5-1mg IV/PO; Maint: 125-250mcg daily", "paediatric_dose": "Premature: 5-10mcg/kg; Term: 10-15mcg/kg; >5yr: 10-15mcg/kg", "notes_updates": "Check levels. Toxicity: nausea, visual changes, arrhythmias"}], "thrombolytics": [{"drug": "Alteplase (tPA)", "adult_dose": "PE: 100mg IV over 2hrs. STEMI: 15mg bolus, 50mg/30min, 35mg/60min", "paediatric_dose": "0.1-0.5mg/kg/hr IV", "notes_updates": "Monitor for bleeding"}, {"drug": "Tenecteplase", "adult_dose": "<60kg:30mg, 60-69:35mg, 70-79:40mg, 80-89:45mg, >90:50mg IV bolus", "paediatric_dose": "Not routinely used", "notes_updates": "Single bolus - preferred for STEMI"}], "anticoagulation": [{"drug": "Heparin (UFH)", "adult_dose": "Loading: 80units/kg IV; Maint: 18units/kg/hr", "paediatric_dose": "Loading: 75units/kg IV; Maint: 20-28units/kg/hr", "notes_updates": "Target aPTT: 50-70sec. Protamine 1mg per 100units heparin"}, {"drug": "Enoxaparin (Clexane)", "adult_dose": "1mg/kg SC 12hrly", "paediatric_dose": "1mg/kg SC 12hrly; <2mo: 1.5mg/kg SC 12hrly", "notes_updates": "Anti-Xa monitoring in renal impairment, pregnancy"}, {"drug": "Warfarin", "adult_dose": "Loading: 5-10mg PO daily; Maint: 2-5mg PO daily", "paediatric_dose": "0.1-0.2mg/kg PO daily", "notes_updates": "Target INR 2-3 for AF/DVT/PE"}], "antiarrhythmics": [{"drug": "Amiodarone", "adult_dose": "Loading: 150mg IV over 10min (may repeat); Maint: 900mg IV over 24hrs", "paediatric_dose": "5mg/kg IV over 30min (may repeat to 15mg/kg)", "notes_updates": "Monitor for hypotension, phlebitis"}, {"drug": "Adenosine", "adult_dose": "6mg IV rapid push (may repeat 12mg)", "paediatric_dose": "0.1mg/kg IV rapid push (max 6mg), then 0.2mg/kg (max 12mg)", "notes_updates": "Half-life <10sec. Must use proximal IV, rapid push followed by flush"}, {"drug": "Magnesium Sulfate", "adult_dose": "Torsades: 2g IV over 10-15min", "paediatric_dose": "25-50mg/kg IV over 15-30min (max 2g)", "notes_updates": "For torsades de pointes, hypomagnesaemia"}], "acute_coronary": [{"drug": "Aspirin", "adult_dose": "300mg PO (then 75mg daily)", "paediatric_dose": "Not routinely used in children", "notes_updates": "Unless true allergy, all ACS patients get aspirin"}, {"drug": "Clopidogrel", "adult_dose": "Loading: 300-600mg PO; Maint: 75mg daily", "paediatric_dose": "Not routinely used", "notes_updates": "If P2Y12 needed and ticagrelor contraindicated"}, {"drug": "Ticagrelor", "adult_dose": "Loading: 180mg PO; Maint: 90mg PO BD", "paediatric_dose": "Not routinely used", "notes_updates": "Preferred P2Y12 for ACS"}, {"drug": "Glyceryl Trinitrate (GTN)", "adult_dose": "Sublingual: 0.3-0.6mg; IV: 10-200mcg/min titrated", "paediatric_dose": "Not routinely used", "notes_updates": "Avoid if SBP <90mmHg, RV infarct, PDE5 inhibitors"}, {"drug": "Morphine", "adult_dose": "2.5-5mg IV (titrate to pain)", "paediatric_dose": "0.05-0.1mg/kg IV", "notes_updates": "For ongoing chest pain despite GTN"}]}}