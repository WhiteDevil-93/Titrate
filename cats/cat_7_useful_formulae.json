{"7_useful_formulae": {"formulae": [{"category": "Inotopes", "item": "Adrenaline", "formula": "ml/hr = (ug/kg/min x kg x 60) / 25", "standard_dilutions": "Single Strength: 5mg (5 amps) in 200ml N/S"}, {"category": "Inotopes", "item": "Noradrenaline", "formula": "ml/hr = (ug/kg/min x kg x 60) / 50", "standard_dilutions": "Double Strength: 10mg in 200ml N/S"}, {"category": "Inotopes", "item": "Dobutamine", "formula": "ml/hr = (ug/kg/min x kg x 60) / 1250", "standard_dilutions": "250mg in 200ml N/S"}, {"category": "Inotopes", "item": "Dopamine", "formula": "ml/hr = (ug/kg/min x kg x 60) / 1000", "standard_dilutions": "200mg in 100ml (5% Dextrose) = 2000mcg/ml"}, {"category": "Inotopes", "item": "Phenylephrine", "formula": "ml/hr = (ug/kg/min x kg x 60) / 100", "standard_dilutions": "10mg in 100ml NS = 100mcg/ml"}, {"category": "Electrolytes", "item": "Sodium Deficit", "formula": "Na deficit = 0.6 x Wt(kg) x (Desired Na - Actual Na)", "standard_dilutions": "Correct max 8-10mmol/L per day"}, {"category": "Electrolytes", "item": "Free Water Deficit", "formula": "Deficit = 0.6 x Wt(kg) x ([Na]/140 - 1)", "standard_dilutions": "Replace slowly over 48-72hrs"}, {"category": "Metabolic", "item": "Anion Gap", "formula": "(Na + K) - (HCO3 + Cl)", "standard_dilutions": "Normal approx 12 mEq/L"}, {"category": "Metabolic", "item": "Corrected Na", "formula": "Measured Na + [1.6 x (Glucose - 5.5) / 5.5]", "standard_dilutions": "Used in hyperglycaemia"}, {"category": "Respiratory", "item": "Oxygenation Index (OI)", "formula": "(MAP x FiO2) / PaO2", "standard_dilutions": ""}, {"category": "Respiratory", "item": "P/F Ratio", "formula": "PaO2 / FiO2", "standard_dilutions": "Normal > 400"}, {"category": "General", "item": "Ideal Body Weight", "formula": "Height (cm) - 100 (approx)", "standard_dilutions": "Use for tidal volume calculation"}, {"category": "Renal", "item": "Osmolality", "formula": "2x[Na] + [Glucose] + [Urea] (all mmol/L)", "standard_dilutions": "Normal: 275-295 mOsm/kg"}, {"category": "Renal", "item": "Osmolar Gap", "formula": "Measured Osmolality - Calculated Osmolality", "standard_dilutions": "Normal < 10"}, {"category": "Cardiac", "item": "Cardiac Output (Fick)", "formula": "CO = VO2 / (Hb x 1.39 x (SaO2 - SvO2))", "standard_dilutions": "Normal: 4-8 L/min"}, {"category": "Cardiac", "item": "Stroke Volume", "formula": "SV = CO / HR", "standard_dilutions": "Normal: 60-100 ml/beat"}, {"category": "Cardiac", "item": "Systemic Vascular Resistance", "formula": "SVR = ((MAP - CVP) / CO) x 80", "standard_dilutions": "Normal: 800-1200 dynes/sec/cm5"}, {"category": "Cardiac", "item": "Pulmonary Vascular Resistance", "formula": "PVR = ((MPAP - PAOP) / CO) x 80", "standard_dilutions": "Normal: <250 dynes/sec/cm5"}, {"category": "Neurological", "item": "Glasgow Coma Scale (GCS)", "formula": "Eye (1-4) + Verbal (1-5) + Motor (1-6)", "standard_dilutions": "Max 15, Min 3"}, {"category": "Paediatric", "item": "ETT Size (Children >1yr)", "formula": "4 + (Age in years) / 4", "standard_dilutions": ""}, {"category": "Paediatric", "item": "ETT Depth (Oral, Children)", "formula": "12 + (Age in years) / 2", "standard_dilutions": "Verify with auscultation and ETCO2"}, {"category": "Paediatric", "item": "Systolic BP (Lower Limit)", "formula": "70 + (2 x Age in years)", "standard_dilutions": "Hypotension if below this value"}, {"category": "Paediatric", "item": "Maintenance Fluids (Holliday-Segar)", "formula": "0-10kg: 100ml/kg/day | 10-20kg: 1000ml + 50ml/kg for each kg >10 | >20kg: 1500ml + 20ml/kg for each kg >20", "standard_dilutions": "Use balanced salt solutions (Plasma-Lyte/Ringer's Lactate)"}, {"category": "General", "item": "Body Surface Area (BSA)", "formula": "sqrt((Height(cm) x Weight(kg)) / 3600)", "standard_dilutions": "Used for drug dosing and fluid requirements"}, {"category": "General", "item": "Temperature Conversion (C to F)", "formula": "(C x 9/5) + 32", "standard_dilutions": ""}, {"category": "General", "item": "Temperature Conversion (F to C)", "formula": "(F - 32) x 5/9", "standard_dilutions": ""}]}}