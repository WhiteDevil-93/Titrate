{"4_antimicrobials_and_infectious_diseases": {"broad_spectrum_antibiotics": [{"condition_or_drug": "Meropenem", "adult_dose": "1-2g IV 8hrly", "paediatric_dose": "20-40mg/kg IV 8hrly", "notes_updates": "Extended infusion: 3-4hr. High dose for meningitis/CNS"}, {"condition_or_drug": "Piperacillin/Tazobactam", "adult_dose": "4.5g IV 6-8hrly", "paediatric_dose": "80-100mg/kg IV 6-8hrly"}, {"condition_or_drug": "Ceftriaxone", "adult_dose": "1-2g IV 12-24hrly", "paediatric_dose": "50-100mg/kg IV 12-24hrly (max 4g/day)"}, {"condition_or_drug": "Ceftazidime", "adult_dose": "1-2g IV 8hrly", "paediatric_dose": "30-50mg/kg IV 8hrly", "notes_updates": "Good pseudomonas coverage"}], "gram_positive": [{"condition_or_drug": "Vancomycin", "adult_dose": "Loading: 25mg/kg; Maint: 15-20mg/kg IV 8-12hrly", "paediatric_dose": "15mg/kg IV 6hrly", "notes_updates": "Trough: 15-20mg/L (severe infections)"}, {"condition_or_drug": "Linezolid", "adult_dose": "600mg IV/PO 12hrly", "paediatric_dose": "10mg/kg IV/PO 8hrly (<12yr)", "notes_updates": "Monitor FBC (myelosuppression). Reserve for VRE/MRSA"}, {"condition_or_drug": "Clindamycin", "adult_dose": "600mg-1.2g IV 6-8hrly", "paediatric_dose": "10-15mg/kg IV 6-8hrly"}], "aminoglycosides": [{"condition_or_drug": "Gentamicin", "adult_dose": "3-5mg/kg IV daily", "paediatric_dose": "2.5mg/kg IV 8hrly", "notes_updates": "Check levels. Extended interval preferred"}, {"condition_or_drug": "Amikacin", "adult_dose": "15mg/kg IV daily", "paediatric_dose": "7.5mg/kg IV 12hrly", "notes_updates": "Check levels"}], "antifungals": [{"condition_or_drug": "Fluconazole", "adult_dose": "Loading: 800mg IV/PO; Maint: 400mg IV/PO daily", "paediatric_dose": "Loading: 12mg/kg; Maint: 6-12mg/kg daily", "notes_updates": "NOT for aspergillus/cryptococcus"}, {"condition_or_drug": "Voriconazole", "adult_dose": "Loading: 6mg/kg IV 12hrly x2; Maint: 4mg/kg IV 12hrly", "paediatric_dose": "Loading: 9mg/kg IV 12hrly x2; Maint: 8mg/kg IV 12hrly", "notes_updates": "Aspergillus first-line"}, {"condition_or_drug": "Amphotericin B", "adult_dose": "1mg/kg IV daily", "paediatric_dose": "1mg/kg IV daily", "notes_updates": "Nephrotoxic. Pre-hydrate and monitor renal function."}], "antivirals": [{"condition_or_drug": "Acyclovir", "adult_dose": "10mg/kg IV 8hrly (HSV); 10-15mg/kg IV 8hrly (VZV/encephalitis)", "paediatric_dose": "10-20mg/kg IV 8hrly", "notes_updates": "Adjust for renal function."}, {"condition_or_drug": "Oseltamivir", "adult_dose": "75mg PO 12hrly", "paediatric_dose": "Dose by weight: <15kg: 30mg; 15-23kg: 45mg; 23-40kg: 60mg; >40kg: 75mg (all 12hrly)", "notes_updates": "Influenza. Start within 48hrs of symptoms."}], "specific_infections": [{"condition_or_drug": "TB Meningitis", "adult_dose": "RHZE: Rifampicin 10mg/kg, Isoniazid 5mg/kg, Pyrazinamide 25mg/kg, Ethambutol 15-20mg/kg (daily for 2 months, then RH for 10 months)", "paediatric_dose": "Same as adult weight-based", "notes_updates": "Add steroids for severe disease."}, {"condition_or_drug": "Cryptococcal Meningitis", "adult_dose": "Amphotericin B 1mg/kg IV daily + Flucytosine 25mg/kg PO 6hrly for 2 weeks, then Fluconazole 400-800mg daily for 8 weeks", "paediatric_dose": "Amphotericin B 1mg/kg + Flucytosine 25mg/kg PO 6hrly", "notes_updates": "HIV patients. Check opening pressure."}]}}