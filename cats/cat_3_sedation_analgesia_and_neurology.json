{"3_sedation_analgesia_and_neurology": {"sedation": [{"drug": "Strategy", "adult_dose": "'Analgesia First'", "paediatric_dose": "N/A", "notes_updates": "Avoid routine deep sedation; prioritize pain control and neuro-psychological support."}, {"drug": "Propofol", "adult_dose": "25 - 50 ug/kg/min (Max 100)", "paediatric_dose": "25 - 60 ug/kg/min", "notes_updates": "Adjust dose in obesity. Caution: Propofol Infusion Syndrome (PRIS)."}, {"drug": "Dexmedetomidine", "adult_dose": "Load: 1ug/kg (10min), Maint: 0.2-0.7 ug/kg/hr", "paediatric_dose": "Same as Adult", "notes_updates": ""}, {"drug": "Ketamine", "adult_dose": "15 - 30 ug/kg/min IV", "paediatric_dose": "5 - 40 ug/kg/min", "notes_updates": "Preferred for asthma/bronchospasm or trauma intubation."}], "seizures": [{"drug": "Lorazepam", "adult_dose": "4 mg IV (repeat once)", "paediatric_dose": "0.05 - 0.2 mg/kg IV", "notes_updates": "First-line for Status Epilepticus."}, {"drug": "Midazolam", "adult_dose": "10mg IM or buccal (if no IV access)", "paediatric_dose": "0.2 - 0.5 mg/kg buccal", "notes_updates": "Alternative if Lorazepam unavailable."}, {"drug": "Valproate", "adult_dose": "Load: 25 mg/kg IV", "paediatric_dose": "Load: 20-40 mg/kg", "notes_updates": "WARNING: High teratogenic risk."}, {"drug": "Levetiracetam", "adult_dose": "Load: 20-30 mg/kg IV", "paediatric_dose": "Load: 50 mg/kg", "notes_updates": "Safer alternative for women of child-bearing potential."}, {"drug": "Phenytoin", "adult_dose": "Loading: 15-20mg/kg IV", "paediatric_dose": "Loading: 15-20mg/kg IV", "notes_updates": "Monitor levels. Max infusion rate 1mg/kg/min"}, {"drug": "Phenobarbitone", "adult_dose": "Loading: 20mg/kg IV", "paediatric_dose": "Loading: 20mg/kg IV", "notes_updates": "Respiratory depression risk"}, {"drug": "Thiopentone", "adult_dose": "75-250mg IV (3-5mg/kg)", "paediatric_dose": "3-5mg/kg IV", "notes_updates": "Requires intubation and ventilation"}], "analgesia": [{"drug": "Fentanyl", "adult_dose": "1 - 2 ug/kg/hr IV", "paediatric_dose": "0.5 - 2 ug/kg/hr IV", "notes_updates": "First-line opioid in ICU."}, {"drug": "Morphine", "adult_dose": "0.05 - 0.2 mg/kg/hr IV", "paediatric_dose": "0.05 - 0.1 mg/kg/hr IV", "notes_updates": "Histamine release. Caution in asthma/hypotension."}, {"drug": "Paracetamol", "adult_dose": "1g IV/PO 6hrly (max 4g/day)", "paediatric_dose": "15mg/kg IV/PO 6hrly", "notes_updates": "First-line analgesic and antipyretic."}, {"drug": "Ketamine", "adult_dose": "0.1-0.5 mg/kg/hr IV", "paediatric_dose": "0.1-0.5 mg/kg/hr IV", "notes_updates": "Analgesic sub-dissociative dose."}], "neurology": [{"drug": "Mannitol", "adult_dose": "0.25-1g/kg IV bolus", "paediatric_dose": "0.25-1g/kg IV bolus", "notes_updates": "Raised ICP. Monitor osmolar gap and electrolytes."}, {"drug": "Hypertonic Saline 3%", "adult_dose": "250ml IV over 30min", "paediatric_dose": "2.5-5ml/kg IV", "notes_updates": "Alternative to Mannitol for raised ICP."}, {"drug": " nimodipine", "adult_dose": "60mg PO 4hrly for 21 days", "paediatric_dose": "Not well established", "notes_updates": "Subarachnoid haemorrhage."}]}}