{"5_metabolic_electrolytes_and_nutrition": {"hyperkalaemia_management": [{"item": "Calcium Chloride 10%", "adult_dose": "1g IV (10ml) slowly over 5-10min", "paediatric_dose": "0.2ml/kg IV slowly (max 10ml)", "notes": "Cardiac membrane stabilisation. Onset: 1-3min"}, {"item": "Calcium Gluconate 10%", "adult_dose": "10ml IV slowly over 5-10min", "paediatric_dose": "0.5ml/kg IV slowly", "notes": "Cardiac membrane stabilisation"}, {"item": "Insulin/Dextrose", "adult_dose": "10 units insulin + 50ml 50% dextrose IV over 15min", "paediatric_dose": "0.1 units/kg + 2ml/kg 25% dextrose IV", "notes": "Drives K+ into cells. Monitor glucose q15min"}, {"item": "Salbutamol", "adult_dose": "10-20mg nebulised over 10min", "paediatric_dose": "4ug/kg IV over 20min", "notes": "Adjunctive. Lowers K+ by 0.5-1mmol/L"}, {"item": "Kayexalate", "adult_dose": "15-30g PO/PR", "paediatric_dose": "1g/kg PO/PR", "notes": "Removes K+ from gut. Slow onset (several hours)"}], "diuretics": [{"item": "Furosemide", "adult_dose": "Bolus: 20-40mg IV; Infusion: 5-40mg/hr", "paediatric_dose": "0.5-1mg/kg IV 8-12hrly", "notes": "Monitor electrolytes. Ototoxicity at high doses"}, {"item": "Mannitol", "adult_dose": "0.25-1g/kg IV bolus", "paediatric_dose": "0.25-1g/kg IV bolus", "notes": "Monitor osmolar gap"}, {"item": "Spironolactone", "adult_dose": "25-100mg PO/NG daily", "paediatric_dose": "1-3mg/kg PO daily", "notes": "Potassium-sparing"}], "vitamins": [{"item": "Vitamin B1 (Thiamine)", "adult_dose": "100mg IV/IM daily", "paediatric_dose": "10-25mg IV/IM daily", "notes": "Give BEFORE glucose in malnourished/alcoholic patients"}, {"item": "Vitamin K", "adult_dose": "10mg IV/PO (warfarin reversal)", "paediatric_dose": "1-2mg IV/PO", "notes": "IV route: anaphylaxis risk (give slowly)"}], "gi_nutrition": [{"item": "Omeprazole", "adult_dose": "40mg IV/PO daily", "paediatric_dose": "0.6-1mg/kg IV/PO daily", "notes": "Stress ulcer prophylaxis"}, {"item": "Metoclopramide", "adult_dose": "10mg IV/IM 8hrly", "paediatric_dose": "0.1-0.2mg/kg IV 6-8hrly", "notes": "Prokinetic. Caution: extrapyramidal effects"}, {"item": "Erythromycin", "adult_dose": "200mg IV 12hrly", "paediatric_dose": "3-5mg/kg IV 6-8hrly", "notes": "Prokinetic (sub-antimicrobial dose)"}], "electrolyte_replacement": [{"item": "Potassium Chloride", "adult_dose": "10-20mmol/hr IV (max 20mmol/hr via central line)", "paediatric_dose": "0.5-1mmol/kg/day IV", "notes": "NEVER give as IV bolus. Monitor ECG."}, {"item": "Magnesium Sulphate", "adult_dose": "2g IV over 15min (emergency); 1-2g IV over 1hr (replacement)", "paediatric_dose": "25-50mg/kg IV (max 2g)", "notes": "Hypomagnesaemia. Torsades de Pointes."}, {"item": "Phosphate", "adult_dose": "0.16-0.32mmol/kg IV over 6-12hrs", "paediatric_dose": "0.16-0.32mmol/kg IV over 6-12hrs", "notes": "Hypophosphataemia. Monitor calcium."}, {"item": "Calcium Gluconate", "adult_dose": "2-4g IV over 10-20min", "paediatric_dose": "0.5-1ml/kg of 10% solution IV", "notes": "Hypocalcaemia. Give slowly."}], "nutrition": [{"item": "Enteral Nutrition", "adult_dose": "Start within 24-48hrs. Target: 20-30kcal/kg/day, Protein: 1.2-2g/kg/day", "paediatric_dose": "Start within 24-48hrs. Target: 60-100kcal/kg/day (infants), 50-70kcal/kg/day (children)", "notes": "Preferred route. Head of bed 30-45 degrees."}, {"item": "TPN (Total Parenteral Nutrition)", "adult_dose": "When enteral not possible for >7 days. Target: 20-30kcal/kg/day", "paediatric_dose": "When enteral not possible. Consult paediatric dietician.", "notes": "Central line required. Monitor LFTs, triglycerides."}, {"item": "Insulin (Glycaemic Control)", "adult_dose": "Sliding scale or infusion to maintain 6-10mmol/L", "paediatric_dose": "Sliding scale or infusion to maintain 6-10mmol/L", "notes": "Avoid hypoglycaemia."}]}}