{"10_endocrine_and_other": {"steroids": [{"drug": "Hydrocortisone", "adult_dose": "Stress: 50-100mg IV 6-8hrly; Physiological: 20mg AM + 10mg PM", "paediatric_dose": "Stress: 1-2mg/kg IV 6hrly", "notes_updates": "Stress dose for adrenal insufficiency, septic shock"}, {"drug": "Dexamethasone", "adult_dose": "4-8mg IV/PO 6hrly", "paediatric_dose": "0.15-0.3mg/kg IV/PO 6hrly", "notes_updates": "Raised ICP, airway oedema, croup"}], "endocrine": [{"drug": "Insulin (Regular)", "adult_dose": "0.1units/kg/hr IV infusion", "paediatric_dose": "0.05-0.1units/kg/hr IV", "notes_updates": "Check glucose hourly. Hold if K+ <3.3"}, {"drug": "Carbimazole", "adult_dose": "20-40mg PO daily then taper", "paediatric_dose": "0.5-0.75mg/kg PO daily", "notes_updates": "Thyrotoxicosis"}, {"drug": "Lugol's Iodine", "adult_dose": "5-10 drops PO 8hrly", "paediatric_dose": "1 drop/yr of age PO 8hrly", "notes_updates": "Thyroid storm - give 1h AFTER carbimazole"}, {"drug": "Octreotide", "adult_dose": "50-100mcg SC/IV 8hrly; Variceal bleed: 50mcg IV bolus then 50mcg/hr", "paediatric_dose": "1-2mcg/kg SC/IV 8hrly", "notes_updates": "For variceal bleeding"}], "other": [{"drug": "Tranexamic Acid", "adult_dose": "1g IV over 10min (repeat 8hrly); Trauma: 1g/10min then 1g/8hrs", "paediatric_dose": "15mg/kg IV 8hrly", "notes_updates": "Contraindicated: significant haematuria, DIC"}, {"drug": "Dantrolene", "adult_dose": "2.5mg/kg IV bolus (may repeat to 10mg/kg)", "paediatric_dose": "2.5mg/kg IV bolus", "notes_updates": "Malignant hyperthermia. Dissolve in sterile water"}]}}