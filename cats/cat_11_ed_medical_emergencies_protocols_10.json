{"11_ed_medical_emergencies": {"protocols": [{"item": "Acute Coronary Syndrome", "protocol_type": "ed_protocol", "sub_protocols": ["STEMI", "NSTE-ACS", "STEMI Equivalents", "Low/Intermediate Risk Chest Pain"], "clinical_features": {"symptoms": ["Chest pain or pressure", "Dyspnoea", "Diaphoresis", "Nausea/vomiting", "Pain radiating to arm, jaw, back", "Syncope or pre-syncope"], "signs": ["Tachycardia", "Hypotension", "Diaphoresis", "New cardiac murmur", "Signs of heart failure (elevated JVP, pulmonary crackles)", "Cardiogenic shock"]}, "risk_factors": ["Age \u2265 65 years", "Smoking", "Family history of CAD", "Diabetes Mellitus", "Hypercholesterolaemia", "Hypertension", "Previous MI", "Drug abuse: cocaine, methamphetamine", "HIV \u00b1 HAART (protease inhibitors)"], "investigations": {"bedside": ["12 & 15 lead ECG (including V4R, V7-9)", "Vital signs and O2 sats", "Finger prick glucose", "VBG"], "lab": ["Troponin I (hs or stat lab)", "U&E", "FBC"], "imaging": ["Portable CXR", "CTPA if PE suspected"]}, "scoring_systems": [{"name": "TIMI Risk Score (NSTE-ACS)", "components": [{"name": "Age \u2265 65 years", "points": 1}, {"name": "\u2265 3 risk factors for CAD", "points": 1}, {"name": "Aspirin use in last 7 days", "points": 1}, {"name": "Recent severe angina (\u2265 2 events in 24 hrs)", "points": 1}, {"name": "Elevated cardiac markers", "points": 1}, {"name": "ST deviation \u2265 0.5mm", "points": 1}, {"name": "Prior coronary artery stenosis \u2265 50%", "points": 1}], "interpretation": [{"range": "0-1", "meaning": "Low Risk (5% event rate)"}, {"range": "2", "meaning": "Low Risk (8% event rate)"}, {"range": "3", "meaning": "Intermediate Risk (13% event rate)"}, {"range": "4", "meaning": "Intermediate Risk (20% event rate)"}, {"range": "5-7", "meaning": "High Risk (26% event rate)"}]}, {"name": "HEART Score", "components": [{"name": "History - Highly suspicious", "points": 2}, {"name": "History - Moderately suspicious", "points": 1}, {"name": "History - Slightly/non-suspicious", "points": 0}, {"name": "ECG - Significant ST depression", "points": 2}, {"name": "ECG - Nonspecific repolarisation disturbance", "points": 1}, {"name": "ECG - Normal", "points": 0}, {"name": "Age \u2265 65 years", "points": 2}, {"name": "Age 45-64 years", "points": 1}, {"name": "Age <45 years", "points": 0}, {"name": "Risk factors \u2265 3", "points": 2}, {"name": "Risk factors 1-2", "points": 1}, {"name": "No risk factors", "points": 0}, {"name": "Troponin \u2265 3x normal limit", "points": 2}, {"name": "Troponin 1-3x normal limit", "points": 1}, {"name": "Troponin \u2264 normal limit", "points": 0}], "interpretation": [{"range": "0-3", "meaning": "Low Risk - discharge or obs unit"}, {"range": "4-6", "meaning": "Moderate Risk - admit for observation"}, {"range": "7-10", "meaning": "High Risk - admit, early invasive strategy"}]}], "drugs": [{"item": "Aspirin", "adult_dose": "300mg PO (then 75mg daily)", "route": "PO", "notes": "Unless true allergy, all ACS patients get aspirin"}, {"item": "Clopidogrel", "adult_dose": "Loading: 300-600mg PO; Maint: 75mg daily", "route": "PO", "notes": "If P2Y12 needed and ticagrelor contraindicated"}, {"item": "Ticagrelor", "adult_dose": "Loading: 180mg PO; Maint: 90mg PO BD", "route": "PO", "notes": "Preferred P2Y12 for ACS"}, {"item": "GTN", "adult_dose": "Sublingual: 0.3-0.6mg; IV: 10-200mcg/min titrated", "route": "Sublingual/IV", "notes": "Avoid if SBP <90mmHg, RV infarct, PDE5 inhibitors"}, {"item": "Morphine", "adult_dose": "2.5-5mg IV (titrate to pain)", "route": "IV", "notes": "For ongoing chest pain despite GTN"}, {"item": "Heparin (UFH)", "adult_dose": "Loading: 80units/kg IV; Maint: 18units/kg/hr", "route": "IV", "notes": "Target aPTT: 50-70sec"}, {"item": "Enoxaparin (Clexane)", "adult_dose": "1mg/kg SC 12hrly", "route": "SC", "notes": "Alternative to UFH"}], "notes": "STEMI: Door-to-balloon <90min, door-to-needle <30min | Reperfusion therapy: PCI preferred if available within 90min, otherwise thrombolysis | MONA: Morphine, Oxygen (if SpO2 <94%), Nitrates, Aspirin | Do not forget to check for aortic dissection, PE, pericardial tamponade"}}]}}