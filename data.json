      },
      {
        "item": "Salbutamol",
        "adult_dose": "Nebulised or IV",
        "paediatric_dose": "4ug/kg IV over 20min",
        "notes": "Adjunctive therapy."
      }
    ],
    "electrolytes": [
      {
        "item": "Potassium (KCl)",
        "adult_dose": "20-40mmol IV in Saline",
        "paediatric_dose": "3-6mmol/kg/day",
        "notes": "Max rate 0.3mmol/kg/hr."
      },
      {
        "item": "Magnesium (MgSO4)",
        "adult_dose": "1-2g IV",
        "paediatric_dose": "25-50mg/kg",
        "notes": ""
      }
    ],
    "nutrition": [
      {
        "item": "Dextrose Warning",
        "adult_dose": ">=12.5% via Central Line",
        "paediatric_dose": "Same",
        "notes": "Peripheral veins risk phlebitis."
      },
      {
        "item": "Vitamins",
        "adult_dose": "Vit B1 (Thiamine) 100mg",
        "paediatric_dose": "5-10mg/kg",
        "notes": "Prevention of Wernicke's."
      }
    ]
  },
