        {
          "drug": "Etomidate",
          "dose": "0.1-0.2mg/kg IV",
          "notes": "Haemodynamically neutral. Brief duration. Myoclonus common."
        }
      ],
      "monitoring": "Continuous pulse oximetry, ECG, BP, capnography. Dedicated observer.",
      "recovery": "Monitor until fully awake, airway reflexes intact, vital signs stable. Discharge criteria met."
    },
    "opioid_toxicity": {
      "signs": "Respiratory depression (RR <10/min), pinpoint pupils, sedation, decreased consciousness",
      "management": [
        "Airway support — bag-valve-mask if needed",
        "Naloxone 0.4-2mg IV, repeat every 2-3 minutes (max 10mg)",
        "If no response after 10mg, consider alternative diagnosis",
        "Monitor for re-sedation (naloxone half-life 30-60 min)",
        "Continuous observation for 2-4 hours post-naloxone"
      ]
    }
