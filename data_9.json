    "procedural_sedation_analgesia": {
      "preparation": [
        "Fasting status assessment (but do not delay emergency procedures)",
        "Airway assessment (Mallampati, neck mobility)",
        "Vital signs baseline",
        "IV access secured",
        "Continuous monitoring: ECG, SpO2, EtCO2, BP",
        "Resuscitation equipment immediately available",
        "Document consent"
      ],
      "agents": [
        {
          "drug": "Ketamine",
          "dose": "1-2mg/kg IV (dissociative sedation). 3-4mg/kg IM.",
          "notes": "Excellent analgesia and amnesia. Preserves airway reflexes. Anti-emetic properties."
        },
        {
          "drug": "Propofol",
          "dose": "1-2mg/kg IV bolus, then 0.5-1mg/kg every 2-3 minutes",
          "notes": "Rapid onset and offset. No analgesia. Risk of hypotension and apnoea."
