  "19_trauma_care": {
    "name": "Trauma Care",
    "category": "trauma",
    "notes_updates": "Advanced Trauma Life Support (ATLS) principles. | Primary survey: ABCDE. | Secondary survey: head-to-toe examination. | Mechanism of injury guides investigation and management. | Consider cervical spine protection throughout. | Paediatric trauma: use paediatric-specific protocols and equipment.",
    "primary_survey": {
      "A_airway": {
        "assess": "Patency, foreign bodies, facial fractures, airway oedema",
        "interventions": [
          "Jaw thrust/chin lift (no head tilt if C-spine concern)",
          "Suction oropharynx",
          "Oropharyngeal airway if unconscious",
          "Nasopharyngeal airway if conscious (no basal skull fracture)",
          "Definitive airway if: GCS ≤8, airway obstruction, severe facial trauma, risk of aspiration"
        ]
      },
      "B_breathing": {
        "assess": "Rate, depth, symmetry, auscultation, tracheal position, chest expansion",
        "life_threatening_conditions": [
          {
            "condition": "Tension pneumothorax",
            "signs": "Respiratory distress, hypotension, tracheal deviation away from affected side, hyper-resonance, distended neck veins",
            "treatment": "Immediate needle decompression 2nd intercostal space midclavicular line, then chest drain"
          },
          {
            "condition": "Open pneumothorax (sucking chest wound)",
            "signs": "Visible chest wound with air movement",
            "treatment": "Occlusive dressing taped on 3 sides, chest drain"
          },
          {
            "condition": "Massive haemothorax",
            "signs": "Decreased breath sounds, dullness to percussion, shock",
            "treatment": "Chest drain (large bore), massive transfusion protocol if needed"
          },
          {
            "condition": "Flail chest",
            "signs": "Paradoxical chest wall movement, crepitus",
            "treatment": "Oxygen, analgesia (regional block preferred), positive pressure ventilation if severe"
          },
          {
            "condition": "Cardiac tamponade",
            "signs": "Beck's triad: hypotension, muffled heart sounds, JVP elevation",
            "treatment": "Pericardiocentesis if unstable, thoracotomy if not immediately available"
          }
        ]
      },
      "C_circulation": {
        "assess": "Pulse rate, BP, capillary refill, skin colour, external bleeding",
        "haemorrhage_control": [
          "Direct pressure",
          "Pressure dressing",
          "Tourniquet (limb exsanguinating haemorrhage) — document time applied",
          "Haemostatic agents",
          "Pelvic binder (suspected pelvic fracture)"
        ],
        "iv_access": [
          "2 large-bore peripheral IVs (14-16G)",
          "IO access if peripheral access fails (within 90 seconds)",
          "Central line if needed for vasopressors/monitoring"
        ],
        "fluid_resuscitation": {
          "adults": "Warm crystalloid (Ringers/Balsol) 1-2L bolus. Target SBP 90-100 (permissive hypotension in penetrating trauma).",
          "paediatric": "20ml/kg bolus. Repeat ×3 if needed. Then blood products.",
          "blood_products": "1:1:1 ratio PRBC:FFP:Platelets for massive haemorrhage. Tranexamic acid 1g IV over 10 minutes if within 3 hours of injury."
        }
      },
      "D_disability": {
        "assess": "GCS, pupillary response, limb movement",
        "interventions": [
          "Treat hypoglycaemia immediately",
          "Consider opioid overdose (naloxone)",
          "Head CT if GCS <15 or focal neurological deficit"
        ]
      },
      "E_exposure": {
        "assess": "Full undress, log-roll, examine back, axillae, perineum",
        "interventions": [
          "Prevent hypothermia — warm fluids, blankets, warming devices",
          "Log-roll with C-spine control"
        ]
      }
    },
    "secondary_survey": {
      "description": "Complete head-to-toe examination after primary survey stabilised.",
      "components": [
        "AMPLE history (Allergies, Medications, Past medical history, Last meal, Events)",
        "Head and face: Scalp lacerations, skull depressions, facial fractures, eye injuries",
        "Neck: Tracheal position, subcutaneous emphysema, seatbelt sign",
        "Chest: Auscultation, percussion, rib tenderness, cardiac assessment",
        "Abdomen: Contusions, seatbelt sign, tenderness, distension, guarding",
        "Pelvis: Stability, tenderness, open fractures",
        "Limbs: Deformity, neurovascular status, open fractures, compartment syndrome",
        "Back: Bruising, tenderness, spinal tenderness",
        "Neurological: Complete neurological examination, GCS trend"
      ]
    },
    "imaging": {
      "FAST": "Focused Assessment with Sonography in Trauma — assess for free fluid in pericardium, perihepatic, perisplenic, pelvis. Positive in hypotensive patient → OR.",
      "eFAST": "Extended FAST — includes pneumothorax assessment (lung sliding).",
      "CT_trauma": "Whole-body CT (pan-scan) for haemodynamically stable patients with significant mechanism.",
      "X-rays": "CXR, pelvic X-ray, C-spine X-ray (or CT) as indicated."
    },
    "special_considerations": {
      "spinal_trauma": {
        "assessment": "Maintain C-spine immobilisation until cleared. CT C-spine for GCS <15 or high-risk criteria. Clinical clearance if awake, alert, no intoxication, no distracting injury, no midline tenderness.",
        "neurogenic_shock": "Hypotension with bradycardia after spinal injury. Treat with fluids and vasopressors. Do not use atropine unless life-threatening bradycardia."
      },
      "head_injury": {
        "mild": "GCS 13-15. CT head if criteria met (NICE/Canadian CT Head Rules).",
        "moderate": "GCS 9-12. CT head urgently. Neurosurgical referral.",
        "severe": "GCS ≤8. Intubate for airway protection. CT head. Neurosurgical referral. ICP management."
      },
      "paediatric_trauma": {
        "differences": [
          "Larger head-to-body ratio — head injuries more common",
          "Higher metabolic rate — hypoglycaemia risk",
          "Greater surface area — heat loss risk",
          "More compliant skeleton — internal injuries without external signs",
          "Use Broselow tape for equipment sizing and drug dosing"
        ],
        "fluid_resuscitation": "20ml/kg warm crystalloid bolus. Blood products if no response after 2 boluses."
      }
    },
    "disposition": "All significant trauma patients require admission. | ICU for haemodynamically unstable, GCS ≤8, multi-system trauma. | Ward for isolated injuries with stable observations. | Transfer to trauma centre if needed."
  },
  "20_toxicology_overdose": {
    "name": "Toxicology & Overdose",
    "category": "toxicology",
    "notes_updates": "General principles of toxicology management. | Supportive care is the mainstay of most poisonings. | Decontamination should not delay definitive care. | Always consider co-ingestants. | Consult toxicology/poisons centre for advice. | Specific antidotes are available for limited number of poisons.",
    "general_principles": {
      "ABCs": "Airway, Breathing, Circulation — stabilise first",
      "decontamination": {
        "activated_charcoal": "50g adult (1g/kg paediatric) if within 1-2 hours of ingestion and airway is protected. Not for: caustics, hydrocarbons, metals, lithium, alcohols.",
        "gastric_lavage": "Rarely indicated. Only if within 1 hour of life-threatening ingestion and airway protected.",
        "whole_bowel_irrigation": "Polyethylene glycol solution. For: sustained-release preparations, iron, lithium, body packers."
      },
      "enhanced_elimination": {
        "urinary_alkalinisation": "For salicylate and methotrexate poisoning. Target urine pH 7.5-8.0.",
        "haemodialysis": "For: methanol, ethylene glycol, lithium, salicylate, theophylline, metformin (severe)."
      },
      "antidotes": {
        "Naloxone": "Opioid overdose — 0.4-2mg IV, repeat PRN",
        "N-acetylcysteine (NAC)": "Paracetamol overdose — IV protocol (standard or modified)"
      }
    },
    "specific_poisonings": {
      "paracetamol_overdose": {
        "toxic_dose": ">10g adult (or >200mg/kg) within 24 hours. Potentially fatal >12g.",
        "assessment": "Rumack-Matthew nomogram for single acute ingestion (4-24 hours post-ingestion). Check paracetamol level, LFTs, INR, renal function.",
        "treatment": [
          "N-acetylcysteine (NAC) IV — standard or modified (2-bag or 3-bag protocol)",
          "Modified King's College: 200mg/kg in 1L over 4h, then 100mg/kg in 1L over 16h",
          "Continue until INR normalises and transaminases falling"
        ],
        "warning": "NAC most effective within 8 hours. Do not delay if potentially toxic ingestion."
      },
      "opioid_overdose": {
        "clinical_features": "Respiratory depression, pinpoint pupils, sedation, hypotension, hypothermia",
        "treatment": [
          "Naloxone 0.4-2mg IV, repeat every 2-3 minutes (max 10mg)",
          "If no IV access: IM, SC, or intranasal (2mg per nare)",
          "Beware of precipitated withdrawal in opioid-dependent patients",
          "Monitor for re-sedation — naloxone half-life 30-60 minutes"
        ]
      },
      "benzodiazepine_overdose": {
        "clinical_features": "Sedation, respiratory depression, ataxia, dysarthria, hypotension",
        "treatment": [
          "Supportive care — airway protection, ventilation if needed",
          "Flumazenil 0.2mg IV, repeat up to 1mg (max 3mg) — ONLY if no co-ingestion of pro-convulsant drug and not chronic benzodiazepine user",
          "Avoid flumazenil in mixed overdoses and chronic users (risk of seizures)"
        ]
      },
      "tricyclic_antidepressant_overdose": {
        "clinical_features": "Anticholinergic effects (dry mouth, urinary retention, tachycardia), seizures, wide QRS (>100ms), hypotension, arrhythmias",
        "treatment": [
          "Sodium bicarbonate 8.4% 50-100ml IV bolus — for QRS >100ms or arrhythmias",
          "Repeat until QRS narrows or pH 7.5-7.55",
          "Avoid class IA and IC antiarrhythmics",
          "Seizures: benzodiazepines"
        ],
        "warning": "QRS >100ms predicts seizures; QRS >160ms predicts ventricular arrhythmias"
      },
      "salicylate_poisoning": {
        "clinical_features": "Tinnitus, vomiting, tachypnoea, metabolic acidosis, respiratory alkalosis, hyperthermia, confusion, seizures",
        "treatment": [
          "Activated charcoal if early",
          "Urinary alkalinisation — target urine pH 7.5-8.0",
          "Haemodialysis for severe poisoning (level >700mg/L, refractory acidosis, renal failure, pulmonary oedema, CNS effects)"
        ]
