  "17_disaster_triage": {
    "name": "Disaster Triage",
    "category": "disaster_management",
    "notes_updates": "Disaster triage protocols for mass casualty incidents. | Principles: Do the greatest good for the greatest number. | Resources are limited; triage decisions must be rapid and systematic. | Re-triage is essential as patient conditions and resources change. | Paediatric patients require specialised triage considerations.",
    "triage_categories": [
      {
        "category": "Immediate (Priority 1 / Red)",
        "description": "Life-threatening but survivable injury with immediate intervention.",
        "examples": [
          "Airway obstruction",
          "Severe respiratory distress",
          "Severe haemorrhage",
          "Tension pneumothorax",
          "Shock (SBP <90 mmHg with weak radial pulse)"
        ],
        "action": "Immediate treatment and transport"
      },
      {
        "category": "Delayed (Priority 2 / Yellow)",
        "description": "Significant injuries but can wait for treatment without deterioration.",
        "examples": [
          "Major fractures",
          "Burns without airway involvement",
          "Stable abdominal injury",
          "Stable spinal injury"
        ],
        "action": "Treatment can be delayed"
      },
      {
        "category": "Minimal (Priority 3 / Green)",
        "description": "Minor injuries, ambulatory patients.",
        "examples": [
          "Minor lacerations",
          "Minor fractures",
          "Soft tissue injuries",
          "Patients who can walk"
        ],
        "action": "Self-care or delayed treatment"
      },
      {
        "category": "Expectant (Priority 4 / Black)",
        "description": "Severe injuries with low probability of survival; resources should be allocated to those more likely to survive.",
        "examples": [
          "Severe head injury with no purposeful response",
          "Cardiac arrest not immediately reversible",
          "Severe burns >80% BSA",
          "Multiple severe injuries with unlikely survival"
        ],
        "action": "Comfort care only — palliative"
      }
    ],
    "triage_systems": {
      "sieve": {
        "name": "Sieve Triage",
        "steps": [
          {
            "step": 1,
            "check": "Can the patient walk?",
            "yes": "MINIMAL (Green) — Send to minor treatment area",
            "no": "Proceed to step 2"
          },
          {
            "step": 2,
            "check": "Is the airway open?",
            "no": "IMMEDIATE (Red) — Open airway immediately",
            "yes": "Proceed to step 3"
          },
          {
            "step": 3,
            "check": "Is the patient breathing?",
            "no": "IMMEDIATE (Red) — If breathing after opening airway, proceed to step 4; if not, EXPECTANT (Black)",
            "yes": "Proceed to step 4"
          },
          {
            "step": 4,
            "check": "Respiratory rate >30 or <10?",
            "yes": "IMMEDIATE (Red)",
            "no": "Proceed to step 5"
          },
          {
            "step": 5,
            "check": "Is radial pulse present? Capillary refill <2 seconds?",
            "no": "IMMEDIATE (Red)",
            "yes": "Proceed to step 6"
          },
          {
            "step": 6,
            "check": "Can the patient obey commands?",
            "no": "IMMEDIATE (Red)",
            "yes": "DELAYED (Yellow)"
          }
        ]
      },
      "jumpstart": {
        "name": "JumpSTART (Paediatric)",
        "steps": [
          {
            "step": 1,
            "check": "Can the child walk?",
            "yes": "MINIMAL (Green)",
            "no": "Proceed to step 2"
          },
          {
            "step": 2,
            "check": "Is the child breathing?",
            "no": "Check airway — if obstructed, attempt to clear. If still not breathing, EXPECTANT (Black) unless respiratory rate improves",
            "yes": "Proceed to step 3"
          },
          {
            "step": 3,
            "check": "Respiratory rate — apnoea or <15 or >45?",
            "yes": "IMMEDIATE (Red)",
            "no": "Proceed to step 4"
          },
          {
            "step": 4,
            "check": "Is pulse palpable at wrist/carotid? (Or HR <60 or >180?)",
            "no": "IMMEDIATE (Red)",
            "yes": "Proceed to step 5"
          },
          {
            "step": 5,
            "check": "Can the child obey commands or make purposeful movement?",
            "no": "IMMEDIATE (Red)",
            "yes": "DELAYED (Yellow)"
          }
        ]
      },
      "sort": {
        "name": "SORT (Simple Triage and Rapid Treatment)",
        "steps": [
          {
            "step": 1,
            "check": "RPM assessment",
            "details": "R = Respiratory rate, P = Pulse (peripheral), M = Mental status (AVPU)"
          },
          {
            "step": 2,
            "check": "Score = 0-2 for each parameter",
            "details": "0 = Normal, 1 = Abnormal, 2 = Severely abnormal"
          },
          {
            "step": 3,
            "check": "Total score interpretation",
            "0": "MINIMAL (Green)",
            "1-3": "DELAYED (Yellow)",
            "4-6": "IMMEDIATE (Red)",
            ">6": "EXPECTANT (Black)"
          }
        ]
      }
    },
    "paediatric_considerations": [
      "Children are more vulnerable to environmental exposure",
      "Use paediatric-specific triage tools (JumpSTART)",
      "Family units should be kept together where possible",
      "Children may decompensate rapidly — frequent re-triage",
      "Paediatric vital signs differ significantly by age group"
    ],
    "retriage": {
      "description": "Re-assessment of triage categories is essential as conditions change and resources become available.",
      "frequency": "Every 15-30 minutes or when clinical status changes",
      "upgrades": "Patients may deteriorate and need upgrading to higher priority",
      "downgrades": "If resources become available, some expectant patients may be re-triaged"
    },
    "documentation": {
      "requirements": [
        "Triage tag number or colour",
        "Time of triage",
        "Clinical findings at triage",
        "Initial vital signs",
        "Treatment given",
        "Time of re-triage"
      ],
      "tools": "Triage tags, wristbands, electronic records"
    }
  },
  "18_pain_management": {
    "name": "Pain Management",
    "category": "analgesia",
    "notes_updates": "Evidence-based pain management guidelines for emergency department. | Multimodal analgesia is preferred. | Consider patient factors: age, comorbidities, allergies, pregnancy, renal/hepatic function. | Reassess pain regularly. | Avoid routine use of parenteral opioids for chronic non-cancer pain. | NSAIDs: Avoid in renal impairment, GI bleeding, anticoagulation. | Opioids: Monitor for sedation and respiratory depression.",
    "analgesic_ladder": {
      "step_1_mild": {
        "description": "Mild pain (1-3/10)",
        "options": [
          {
            "drug": "Paracetamol (Acetaminophen)",
            "dose": "Adult: 1g PO/IV every 4-6 hours (max 4g/day). Paediatric: 15mg/kg PO every 4-6 hours (max 60mg/kg/day).",
            "notes": "First-line for mild pain. Hepatotoxic in overdose."
          },
          {
            "drug": "NSAIDs (if no contraindications)",
            "dose": "Ibuprofen 400-600mg PO TDS or Diclofenac 50mg PO TDS",
            "notes": "Avoid in renal impairment, GI bleeding, anticoagulation, heart failure."
          }
        ]
      },
      "step_2_moderate": {
        "description": "Moderate pain (4-6/10)",
        "options": [
          {
            "drug": "Paracetamol + NSAID combination",
            "dose": "Paracetamol 1g + Ibuprofen 400mg PO",
            "notes": "Synergistic effect. Monitor for NSAID side effects."
          },
          {
            "drug": "Tramadol",
            "dose": "Adult: 50-100mg PO every 4-6 hours (max 400mg/day). Paediatric: 1-2mg/kg PO every 4-6 hours.",
            "notes": "Weak opioid. Risk of seizures at high doses."
          },
          {
            "drug": "Codeine",
            "dose": "Adult: 30-60mg PO every 4-6 hours (max 240mg/day)",
            "notes": "Variable metabolism (CYP2D6). Use with caution."
          }
        ]
      },
      "step_3_severe": {
        "description": "Severe pain (7-10/10)",
        "options": [
          {
            "drug": "Morphine",
            "dose": "Adult: 0.1-0.2mg/kg IV (usual 5-10mg), titrate every 5-10 minutes. Paediatric: 0.05-0.1mg/kg IV.",
            "notes": "First-line strong opioid. Monitor for sedation and respiratory depression."
          },
          {
            "drug": "Fentanyl",
            "dose": "Adult: 1-2mcg/kg IV (usual 50-100mcg), titrate. Paediatric: 1-2mcg/kg IV/IN.",
            "notes": "Rapid onset (1-2 min). Short duration (30-60 min). Suitable for procedures."
          },
          {
            "drug": "Ketamine (low dose)",
            "dose": "Adult: 0.1-0.3mg/kg IV (analgesic dose). Paediatric: 0.2-0.5mg/kg IV/IM.",
            "notes": "Excellent for severe pain, especially trauma. Preserves airway reflexes."
          }
        ]
      }
    },
    "regional_analgesia": {
      "digital_nerve_block": {
        "indication": "Finger/toe injuries",
        "technique": "2-5ml plain lignocaine 1% at base of digit on each side (total 4-10ml). No adrenaline.",
        "duration": "1-2 hours"
      },
      "femoral_nerve_block": {
        "indication": "Femoral shaft fracture, hip fracture",
        "technique": "20-30ml lignocaine 1% or bupivacaine 0.25% lateral to femoral artery below inguinal ligament",
        "duration": "2-4 hours (lignocaine), 4-8 hours (bupivacaine)"
      },
      "haematoma_block": {
        "indication": "Distal radius fracture reduction",
        "technique": "10-15ml lignocaine 1% injected into fracture haematoma",
        "duration": "1-2 hours"
      },
      "intercostal_nerve_block": {
        "indication": "Rib fractures",
        "technique": "3-5ml lignocaine 1% at posterior angle of rib (neurovascular bundle inferior to rib)",
        "duration": "4-8 hours"
      }
    },
    "special_populations": {
      "paediatric": {
        "notes": "Use weight-based dosing. FLACC or Wong-Baker FACES for assessment.",
        "drugs": [
          {
            "drug": "Paracetamol",
            "dose": "15mg/kg PO/PR every 4-6 hours"
          },
          {
            "drug": "Ibuprofen",
            "dose": "5-10mg/kg PO every 6-8 hours (avoid <6 months)"
          },
          {
            "drug": "Fentanyl IN",
            "dose": "1-2mcg/kg intranasal (max 100mcg per nare)"
          },
          {
            "drug": "Ketamine",
            "dose": "0.5-1mg/kg IV for procedural sedation/analgesia"
          }
        ]
      },
      "elderly": {
        "notes": "Start low, go slow. Increased risk of sedation, falls, constipation. Reduce opioid doses by 25-50%.",
        "cautions": [
          "Increased sensitivity to opioids",
          "Risk of falls with sedation",
          "Renal impairment limits NSAID use",
          "Polypharmacy interactions"
        ]
      },
      "pregnancy": {
        "notes": "Avoid NSAIDs in 3rd trimester. Paracetamol is safe. Opioids: use short-term, risk of neonatal withdrawal.",
        "safe_drugs": ["Paracetamol", "Opioids (short-term)", "Lignocaine (local)"],
        "avoid": ["NSAIDs (3rd trimester)", "Aspirin (high dose)"]
      },
      "renal_impairment": {
        "notes": "Avoid NSAIDs. Reduce opioid doses. Avoid morphine metabolites — consider fentanyl.",
